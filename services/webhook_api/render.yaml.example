services:
  - type: web
    name: stucha-webhook-api
    runtime: python
    rootDir: services/webhook_api
    buildCommand: pip install -r requirements.txt
    startCommand: uvicorn app.main:app --host 0.0.0.0 --port $PORT
    healthCheckPath: /healthz
    envVars:
      - key: DATABASE_URL
        sync: false
      - key: DATABASE_SSL
        value: true
      - key: JOTFORM_WEBHOOK_SECRET
        sync: false
      - key: ADMIN_API_KEY
        sync: false
      - key: GOOGLE_SHEET_ID
        sync: false
      - key: GOOGLE_SHEET_TAB
        value: Loans
      - key: GOOGLE_SERVICE_ACCOUNT_JSON_B64
        sync: false
