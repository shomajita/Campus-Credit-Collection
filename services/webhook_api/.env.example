# Render/Railway database connection
# Paste the rotated Railway PostgreSQL URL in Render only. Do not commit the real value.
DATABASE_URL=postgresql://postgres:replace-me@host:5432/railway
DATABASE_SSL=true

# Webhook security
JOTFORM_WEBHOOK_SECRET=replace-with-a-long-random-secret
ADMIN_API_KEY=replace-with-a-different-long-random-secret

# Optional Google Sheets sync
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Loans
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# App
APP_ENV=production
